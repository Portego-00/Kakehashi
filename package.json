  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/react-native": "^12.3.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.3",
    "@types/pako": "^2.0.4",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "jest-fetch-mock": "^3.0.3",
    "jsdom": "^20.0.3",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-ml-kit/text-recognition",
          "expo-modules-jsi",
          "react-native-vector-icons",
          "react-native-vlc-media-player"
        ]
      }
    }
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|wanakana)"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/test.js",
      "<rootDir>/test.ts"
    ]
  }
}
