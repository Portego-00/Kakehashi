{
  "name": "kakehashi",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "postinstall": "patch-package",
    "reset-project": "node ./scripts/reset-project.js",
    "import:wanikani-patterns-repo": "node ./scripts/importWaniKaniPatternsFromRepo.mjs",
    "scrape:wanikani-patterns": "node ./scripts/scrapeWaniKaniPatterns.mjs",
    "scrape:wanikani-patterns:retry-failures": "ONLY_RETRY_PREVIOUS_FAILURES=1 node ./scripts/scrapeWaniKaniPatterns.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest"
  },
  "dependencies": {
    "@bacons/apple-targets": "^4.0.7",
